generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./hostel.db"
}

model Room {
  id               String    @id
  number           String
  type             String
  status           String
  capacity         Int
  currentOccupants Int
  pricePerMonth    Float
  students         Student[] @relation("RoomToStudent")
}

model Student {
  id            String   @id
  name          String
  email         String
  phone         String
  roomNumber    String
  roomId        String?
  course        String
  admissionDate String
  status        String
  room          Room?    @relation("RoomToStudent", fields: [roomId], references: [id])
}

model Payment {
  id          String @id
  studentId   String
  studentName String
  roomNumber  String
  amount      Float
  date        String
  month       String
  status      String
  method      String
}

model Complaint {
  id          String @id
  studentId   String
  studentName String
  roomNumber  String
  title       String
  description String
  date        String
  status      String
  priority    String
}
